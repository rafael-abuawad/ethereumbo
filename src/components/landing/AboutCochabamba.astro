---
import { MapPin, Cpu, UtensilsCrossed, Sun, TreePine } from 'lucide-react';
import { Card } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';

const COCHABAMBA_IMAGE_URL = '/images/cristo-de-la-concordia.png';

const features = [
	{ icon: MapPin, title: 'Corazón de Bolivia', description: 'Punto de encuentro estratégico en el centro.' },
	{ icon: Cpu, title: 'Hub Tecnológico', description: 'Ecosistema de desarrolladores.' },
	{ icon: UtensilsCrossed, title: 'Capital Culinaria', description: 'Experiencias gastronómicas increíbles.' },
	{ icon: Sun, title: 'Vibras Solarpunk', description: 'Futuro sostenible encontrando la tradición.' },
];
---

<section class="w-full bg-background py-24" id="about">
	<div class="max-w-[1280px] mx-auto px-6 lg:px-12 w-full @container">
		<div class="grid lg:grid-cols-2 gap-20 items-center">
			<div class="flex flex-col gap-8 order-2 lg:order-1">
				<div class="flex flex-col gap-4">
					<Badge variant="outline">LA SEDE</Badge>
					<h2 class="text-foreground text-4xl md:text-5xl font-bold leading-tight tracking-tight">Sobre Cochabamba</h2>
				</div>
				<p class="text-muted-foreground text-lg leading-relaxed font-light">
					Descubre la "Ciudad de la Eterna Primavera", el emergente hub tecnológico de los Andes. Anidada en un valle dentro de la cordillera de los Andes, Cochabamba ofrece el clima perfecto para la innovación, combinando ambición moderna con rico patrimonio cultural.
				</p>
				<div class="grid sm:grid-cols-2 gap-6 mt-4">
					{features.map(({ icon: Icon, title, description }) => (
						<Card className="flex flex-row gap-4 p-5 rounded-2xl bg-muted border border-border transition-colors shadow-none">
							<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-background text-primary shadow-sm">
								<Icon className="size-5" />
							</div>
							<div class="flex flex-col gap-1">
								<h3 class="text-foreground font-semibold text-sm">{title}</h3>
								<p class="text-muted-foreground text-xs leading-relaxed">{description}</p>
							</div>
						</Card>
					))}
				</div>
			</div>
			<div class="relative order-1 lg:order-2 h-full min-h-[500px] w-full rounded-3xl overflow-hidden shadow-2xl shadow-muted-foreground/10 group bg-muted">
				<img
					src={COCHABAMBA_IMAGE_URL}
					alt="Vista del mapa del centro de Cochabamba"
					class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
				/>
				<div class="absolute inset-0 bg-linear-to-t from-black/60 via-transparent to-transparent" />
				<div class="absolute bottom-8 left-8 right-8">
					<div class="inline-flex items-center gap-3 px-4 py-3 rounded-2xl bg-background/95 backdrop-blur-md shadow-lg">
						<div class="h-10 w-10 rounded-full bg-green-50 dark:bg-green-950/50 flex items-center justify-center text-green-600 dark:text-green-400 border border-green-100 dark:border-green-900">
							<TreePine className="size-5" />
						</div>
						<div>
							<p class="text-foreground font-bold text-sm">Cristo de la Concordia</p>
							<p class="text-muted-foreground text-xs">Monumento icónico</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
