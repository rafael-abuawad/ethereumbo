---
import { MapPin, Cpu, UtensilsCrossed, Sun, TreePine } from "lucide-react";
import { Card } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";

const COCHABAMBA_IMAGE_URL = "/images/cristo-de-la-concordia.png";

const features = [
  {
    icon: MapPin,
    title: "Corazón de Bolivia",
    description: "Punto de encuentro estratégico en el centro.",
  },
  {
    icon: Cpu,
    title: "Hub Tecnológico",
    description: "Ecosistema de desarrolladores.",
  },
  {
    icon: UtensilsCrossed,
    title: "Capital Culinaria",
    description: "Experiencias gastronómicas increíbles.",
  },
  {
    icon: Sun,
    title: "Vibras Solarpunk",
    description: "Futuro sostenible encontrando la tradición.",
  },
];
---

<section class="relative w-full bg-background py-24 md:py-28" id="about">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-12 w-full @container relative">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-20 items-center">
      <div class="flex flex-col gap-8 order-2 lg:order-1">
        <div class="flex flex-col gap-4">
          <Badge
            variant="outline"
            className="w-fit border-primary/30 bg-primary/5 text-primary font-semibold tracking-wide uppercase text-[0.65rem] py-1"
            >LA SEDE</Badge
          >
          <h2
            class="font-display text-foreground text-4xl md:text-5xl lg:text-[3.25rem] font-semibold leading-[1.05] tracking-tight"
          >
            Sobre Cochabamba
          </h2>
        </div>
        <p
          class="text-muted-foreground text-lg leading-relaxed font-normal max-w-xl"
        >
          Descubre la "Ciudad de la Eterna Primavera", el emergente hub
          tecnológico de los Andes. Anidada en un valle dentro de la cordillera
          de los Andes, Cochabamba ofrece el clima perfecto para la innovación,
          combinando ambición moderna con rico patrimonio cultural.
        </p>
        <div class="grid sm:grid-cols-2 gap-5 mt-2">
          {
            features.map(({ icon: Icon, title, description }) => (
              <Card className="group flex flex-row gap-4 p-5 rounded-2xl bg-card/80 border border-border/80 transition-all duration-300 shadow-none hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary ring-1 ring-border transition-colors group-hover:bg-primary/15">
                  <Icon className="size-5" />
                </div>
                <div class="flex flex-col gap-1">
                  <h3 class="text-foreground font-semibold text-sm">{title}</h3>
                  <p class="text-muted-foreground text-xs leading-relaxed">
                    {description}
                  </p>
                </div>
              </Card>
            ))
          }
        </div>
      </div>
      <div
        class="relative order-1 lg:order-2 h-full min-h-[500px] w-full lg:translate-x-2"
      >
        <div
          class="relative h-full min-h-[500px] w-full rounded-3xl overflow-hidden ring-1 ring-border/60 shadow-lg group bg-muted"
        >
          <img
            src={COCHABAMBA_IMAGE_URL}
            alt="Vista del mapa del centro de Cochabamba"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 ease-out group-hover:scale-[1.03]"
          />
          <div
            class="absolute inset-0 bg-linear-to-t from-black/70 via-black/20 to-transparent"
          >
          </div>
          <div class="absolute bottom-8 left-8 right-8">
            <div
              class="inline-flex items-center gap-3 px-4 py-3 rounded-2xl bg-background/95 backdrop-blur-md border border-border shadow-md"
            >
              <div
                class="h-10 w-10 rounded-full bg-muted flex items-center justify-center text-primary border border-border"
              >
                <TreePine className="size-5" />
              </div>
              <div>
                <p class="text-foreground font-bold text-sm">
                  Cristo de la Concordia
                </p>
                <p class="text-muted-foreground text-xs">Monumento icónico</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
