---
import { Button } from "@/components/ui/button";
import { WavyBackground } from "@/components/ui/wavy-background";
---

<WavyBackground className="h-full w-full" client:idle>
  <div class="flex flex-col items-center justify-center h-full min-h-screen">
    <div
      class="relative z-10 w-full max-w-[1280px] mx-auto px-6 lg:px-12 flex flex-col gap-8 text-center items-center"
    >
      <div
        class="animate-fade-up inline-flex items-center justify-center gap-2.5 px-5 py-2 rounded-full border border-primary/20 bg-primary/10 backdrop-blur-md"
      >
        <span
          class="size-1.5 rounded-full bg-primary shrink-0"
          aria-hidden="true"></span>
        <span
          class="text-xs font-semibold text-white/95 uppercase tracking-[0.2em] font-sans"
          >Septiembre · Cochabamba</span
        >
      </div>
      <h1
        class="font-display text-white text-5xl md:text-7xl lg:text-[5.25rem] font-semibold leading-[0.92] tracking-tight max-w-5xl"
      >
        <span class="block animate-fade-up animate-fade-up-delay-1"
          >Buildathon</span
        >
        <span
          class="block animate-fade-up animate-fade-up-delay-2 text-white/95 italic font-medium"
          >Cochabamba</span
        >
        <span
          class="block mt-1 text-4xl md:text-6xl lg:text-7xl text-white/90 tabular-nums animate-fade-up animate-fade-up-delay-3"
          >2026</span
        >
      </h1>
      <p
        class="text-white/90 text-lg md:text-xl font-normal leading-relaxed max-w-xl mx-auto font-sans animate-fade-up animate-fade-up-delay-4"
      >
        La hackathon de blockchain más importante en el corazón de Bolivia.
        Construyendo el futuro de la web descentralizada con energía solarpunk
        en los Andes.
      </p>
      <div
        class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-up animate-fade-up-delay-5"
      >
        <a href="/road-to-buildathon/" class="hover:cursor-pointer">
          <Button size="lg" variant="secondary" className="rounded-full">
            Road to Buildathon
          </Button>
        </a>
      </div>
    </div>
  </div>
</WavyBackground>
