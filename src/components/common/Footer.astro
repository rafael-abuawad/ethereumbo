---
import { Send, Instagram, Facebook, Linkedin, Twitter } from "lucide-react";
import { ModeToggle } from "./ModeToggle";
import { Button } from "../ui/button";

const socialLinks = [
  { href: "https://t.me/EthereumBo", icon: Send, label: "Telegram" },
  {
    href: "https://www.instagram.com/ethereumbo/",
    icon: Instagram,
    label: "Instagram",
  },
  {
    href: "https://www.facebook.com/EthereumBo",
    icon: Facebook,
    label: "Facebook",
  },
  {
    href: "https://www.linkedin.com/company/ethereumbo/",
    icon: Linkedin,
    label: "LinkedIn",
  },
  { href: "https://x.com/EthereumBo", icon: Twitter, label: "X" },
];
---

<footer
  class="relative bg-background border-t border-border/80 overflow-hidden"
>
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-border"
    aria-hidden="true"
  >
  </div>
  <div
    class="max-w-[1280px] mx-auto flex flex-col gap-8 px-6 lg:px-12 py-14 items-center relative z-10"
  >
    <a
      href="/"
      class="flex items-center gap-2 transition-opacity hover:opacity-90"
    >
      <span class="flex items-center gap-2 dark:hidden">
        <img src="/images/15_isotipo_magenta.png" alt="" class="h-10 w-auto" />
        <img
          src="/images/12_logotipo_magenta.png"
          alt="Ethereum Bolivia"
          class="h-14 w-auto"
        />
      </span>
      <span class="hidden dark:flex items-center gap-2">
        <img src="/images/16_isotipo_blanco.png" alt="" class="h-10 w-auto" />
        <img
          src="/images/13_logotipo_blanco.png"
          alt="Ethereum Bolivia"
          class="h-14 w-auto"
        />
      </span>
    </a>
    <div class="flex flex-wrap justify-center gap-3 sm:gap-4">
      {
        socialLinks.map(({ href, icon: Icon, label }) => (
          <a href={href} target="_blank" rel="noopener noreferrer">
            <Button
              variant="ghost"
              size="icon"
              aria-label={label}
              className="text-muted-foreground rounded-full size-11 border border-transparent hover:border-primary/25 hover:bg-primary/10 hover:text-primary transition-all duration-200"
            >
              <Icon className="size-5" />
            </Button>
          </a>
        ))
      }
      <ModeToggle client:load />
    </div>
    <div class="flex flex-col gap-2 mt-2 items-center">
      <p class="text-muted-foreground text-xs text-center max-w-md">
        © 2026 Ethereum Bolivia. Todos los derechos reservados.
      </p>
      <p class="text-muted-foreground text-xs text-center">
        Hecho por <a
          href="https://rafael-abuawad.github.io/"
          target="_blank"
          rel="noopener noreferrer"
          class="nav-link-accent font-medium text-foreground/90 hover:text-primary"
          >Rafael Abuawad</a
        >
      </p>
    </div>
  </div>
</footer>
