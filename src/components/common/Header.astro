---
import { Button } from "@/components/ui/button";
import { MenuIcon, XIcon } from "lucide-react";
---

<header
  x-data="{ open: false }"
  class="sticky top-0 z-50 w-full border-b border-border/80 bg-background/80 backdrop-blur-xl backdrop-saturate-150 shadow-sm"
>
  <div
    class="mx-auto max-w-[1280px] px-6 lg:px-12 py-5 flex items-center justify-between whitespace-nowrap"
  >
    <a
      href="/"
      class="flex items-center gap-2 transition-opacity hover:opacity-90"
    >
      <span class="flex items-center gap-2 dark:hidden">
        <img src="/images/15_isotipo_magenta.png" alt="" class="h-12 w-auto" />
        <img
          src="/images/12_logotipo_magenta.png"
          alt="Ethereum Bolivia"
          class="h-16 w-auto"
        />
      </span>
      <span class="hidden dark:flex items-center gap-2">
        <img src="/images/16_isotipo_blanco.png" alt="" class="h-12 w-auto" />
        <img
          src="/images/13_logotipo_blanco.png"
          alt="Ethereum Bolivia"
          class="h-16 w-auto"
        />
      </span>
    </a>
    <div class="hidden lg:flex flex-1 justify-end gap-10">
      <nav class="flex items-center gap-8">
        <a
          href="/"
          class="nav-link-accent text-muted-foreground hover:text-foreground text-sm font-semibold"
        >
          Inicio
        </a>
        <a
          href="/road-to-buildathon/"
          class="nav-link-accent text-muted-foreground hover:text-foreground text-sm font-semibold"
        >
          Road To Buildathon
        </a>
      </nav>
      <a href="/register">
        <Button size="lg" className="rounded-full shadow-sm">
          Regístrate ahora
        </Button>
      </a>
    </div>
    <button
      @click="open = !open"
      :aria-expanded="open"
      type="button"
      class="lg:hidden p-2 text-foreground hover:bg-muted rounded-md transition-colors [&_svg]:size-6"
      aria-label="Toggle menu"
    >
      <span x-show="!open"><MenuIcon /></span>
      <span x-show="open" x-cloak><XIcon /></span>
    </button>
  </div>

  <div
    x-show="open"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-2"
    x-effect="document.body.classList.toggle('overflow-hidden', open)"
    @click.outside="open = false"
    x-cloak
    class="lg:hidden border-t border-border/80 bg-background/95 backdrop-blur-xl"
  >
    <nav class="mx-auto max-w-[1280px] px-6 py-6 flex flex-col gap-4">
      <a
        href="/"
        @click="open = false"
        class="text-muted-foreground hover:text-foreground text-base font-semibold transition-colors py-2"
        >Inicio</a
      >
      <a
        href="/road-to-buildathon/"
        @click="open = false"
        class="text-muted-foreground hover:text-foreground text-base font-semibold transition-colors py-2"
        >Road To Buildathon</a
      >
      <a href="/register" @click="open = false">
        <Button size="lg" className="rounded-full w-full mt-2 shadow-sm">
          Regístrate ahora
        </Button>
      </a>
    </nav>
  </div>
</header>
