---
import { Button } from '@/components/ui/button';
import { ModeToggle } from './ModeToggle';

// Inline SVG icons - no React
const GemIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.5 3 8 9l4 13 4-13-2.5-6"/><path d="M17 3a2 2 0 0 1 1.6.8l3 4a2 2 0 0 1 .013 2.382l-7.99 10.986a2 2 0 0 1-3.247 0l-7.99-10.986A2 2 0 0 1 2.4 7.8l2.998-3.997A2 2 0 0 1 7 3z"/><path d="M2 9h20"/></svg>`;
const MenuIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h16"/><path d="M4 12h16"/><path d="M4 19h16"/></svg>`;
---

<header class="sticky top-0 z-50 w-full bg-background/90 backdrop-blur-sm border-b border-border">
	<div class="mx-auto max-w-[1280px] px-6 lg:px-12 py-5 flex items-center justify-between whitespace-nowrap">
		<a href="/" class="flex items-center gap-3">
			<div class="size-8 flex items-center justify-center text-primary [&_svg]:size-7"><span set:html={GemIcon} /></div>
			<h2 class="text-foreground text-base font-semibold tracking-tight">Ethereum Bolivia</h2>
		</a>
		<div class="hidden lg:flex flex-1 justify-end gap-10">
			<nav class="flex items-center gap-8">
				<ModeToggle client:load />
				<a href="/" class="text-muted-foreground hover:text-foreground text-sm font-medium transition-colors">Inicio</a>
				<a href="/road-to-buildathon/" class="text-muted-foreground hover:text-foreground text-sm font-medium transition-colors">Road To Buildathon</a>
			</nav>
			<Button size="lg" className="rounded-full">
				<a href="/register">Regístrate ahora</a>
			</Button>
		</div>
		<button type="button" class="lg:hidden p-2 text-foreground hover:bg-muted rounded-md transition-colors [&_svg]:size-6" aria-label="Open menu"><span set:html={MenuIcon} /></button>
	</div>
</header>
