---
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { cityConfig } from "@/lib/road-to-buildathon/events";

type CitySlug = "cochabamba" | "santa-cruz" | "la-paz";

interface Props {
  activeCity: CitySlug;
}

const { activeCity } = Astro.props;

const cities = [
  cityConfig.cochabamba,
  cityConfig["santa-cruz"],
  cityConfig["la-paz"],
] as const;
---

<section
  class="w-full max-w-[1280px] mx-auto px-6 lg:px-12 py-16 md:py-24 flex flex-col items-center text-center"
>
  <div class="inline-flex items-center gap-2 mb-6">
    <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
    <Badge
      variant="outline"
      className="text-muted-foreground text-xs font-mono uppercase tracking-wider"
      >Track Oficial</Badge
    >
  </div>
  <h1
    class="text-foreground text-4xl md:text-6xl font-bold leading-tight tracking-tight mb-8"
  >
    Road to Buildathon
  </h1>
  <p
    class="text-muted-foreground text-lg max-w-xl font-light leading-relaxed mb-10"
  >
    Una serie de talleres, meetups y sesiones de hacking para prepararte para el
    evento principal.
  </p>
  <div class="flex flex-wrap justify-center gap-3">
    {
      cities.map((city) => {
        const isActive = city.slug === activeCity;
        return (
          <Button
            variant={isActive ? "default" : "outline"}
            size="lg"
            className="rounded-full"
          >
            <a href={city.path}>{city.name}</a>
          </Button>
        );
      })
    }
  </div>
</section>
