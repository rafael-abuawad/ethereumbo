{
  "name": "ethereumbo",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "lint:ci": "oxlint --deny-warnings src",
    "format": "prettier --write \"**/*.astro\" && oxfmt --write ./src",
    "format:check": "prettier --check \"**/*.astro\" && oxfmt --check ./src"
  },
  "dependencies": {
    "@astrojs/alpinejs": "^0.5.0",
    "@astrojs/react": "^5.0.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/alpinejs": "^3.13.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "alpinejs": "^3.15.8",
    "astro": "^6.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "simplex-noise": "^4.0.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "oxfmt": "^0.36.0",
    "oxlint": "^1.57.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "shadcn": "^3.8.5",
    "tw-animate-css": "^1.4.0"
  }
}
